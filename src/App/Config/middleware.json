{
  "middleware": [
    {
      "Curlpit\\Core\\Middleware\\ErrorHandlerMiddleware": {
        "debug": false
      }
    },
    {
      "DbCommander\\Http\\Middleware\\CorsMiddleware": {
        "allowed_origins": ["*"]
      }
    },
    {
      "DbCommander\\Http\\Middleware\\JsonResponseMiddleware": {
        "debug": false
      }
    },
    {
      "Curlpit\\Core\\Middleware\\RoutingMiddleware": {
        "routes": [
          { "method": "GET",    "path": "/",                                       "handler": "FrontendHandler"       },
          { "method": "GET",    "path": "/api/connections",                        "handler": "ConnectionListHandler" },
          { "method": "GET",    "path": "/api/databases",                          "handler": "DatabaseListHandler"   },
          { "method": "GET",    "path": "/api/databases/{db}/tables",              "handler": "TableListHandler"      },
          { "method": "GET",    "path": "/api/tables/{db}/{table}/rows",           "handler": "RowListHandler"        },
          { "method": "GET",    "path": "/api/tables/{db}/{table}/structure",      "handler": "StructureHandler"      },
          { "method": "POST",   "path": "/api/sql",                                "handler": "SqlHandler"            },
          { "method": "POST",   "path": "/api/copy",                               "handler": "CopyTableHandler"      },
          { "method": "PUT",    "path": "/api/tables/{db}/{table}/rows",           "handler": "UpdateRowHandler"      },
          { "method": "PUT",    "path": "/api/tables/{db}/{table}/structure",      "handler": "ModifyColumnHandler"   },
          { "method": "DELETE", "path": "/api/tables/{db}/{table}",                "handler": "DropTableHandler"      }
        ]
      }
    },
    {
      "Curlpit\\Core\\Middleware\\JumpMiddleware": {
        "condition": {
          "type": "attr",
          "name": "__route_handler",
          "eq":   "ConnectionListHandler"
        },
        "jump_to_label": "dispatch"
      }
    },
    {
      "Curlpit\\Core\\Middleware\\JumpMiddleware": {
        "condition": {
          "type": "attr",
          "name": "__route_handler",
          "eq":   "FrontendHandler"
        },
        "jump_to_label": "dispatch"
      }
    },
    {
      "DbCommander\\Http\\Middleware\\ConnectionMiddleware": {}
    },
    {
      "Curlpit\\Core\\Middleware\\JumpMiddleware": {
        "condition": {
          "type": "attr",
          "name": "__connection_error"
        },
        "jump_to_label": "dispatch"
      }
    },
    {
      "Curlpit\\Core\\Middleware\\DispatchMiddleware": {
        "label": "dispatch"
      }
    }
  ]
}
