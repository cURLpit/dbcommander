{
  "name": "dbcommander/dbcommander",
  "description": "Norton Commander-style MySQL manager built on Curlpit",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "psr/http-message": "^1.1|^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/http-factory": "^1.0",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1",
    "curlpit/curlpit": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "DbCommander\\": "src/DbCommander/",
      "DbCommander\\Asset\\": "src/Asset/",
      "DbCommander\\Composer\\": "src/Composer/",
      "DbCommander\\Config\\": "src/Config/",
      "DbCommander\\Driver\\": "src/Driver/",
      "DbCommander\\Exception\\": "src/Exception/",
      "DbCommander\\Http\\": "src/Http/",
      "DbCommander\\Repository\\": "src/Repository/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "DbCommander\\Composer\\ScriptHandler::postInstall"
    ],
    "post-update-cmd": [
      "DbCommander\\Composer\\ScriptHandler::postInstall"
    ]
  }
}
